{
  "expo": {
    "name": "Inventory",
    "slug": "Inventory",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/inv-icon.png",
    "scheme": "inventory",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": true,
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Allow Inventory to use the camera to scan product barcodes."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "icon": "./assets/images/inv-icon.png"
      },
      "softwareKeyboardLayoutMode": "pan",
      "permissions": [
        "CAMERA",
        "android.permission.CAMERA",
        "android.permission.RECORD_AUDIO"
      ],
      "edgeToEdgeEnabled": true,
      "predictiveBackGestureEnabled": false,
      "package": "com.q_allen.Inventory"
    },
    "web": {
      "output": "static",
      "favicon": "./assets/images/favicon.png"
    },
    "plugins": [
      "expo-router",
      "expo-font",
      "expo-camera",
      "expo-sqlite"
    ],
    "experiments": {
      "typedRoutes": true,
      "reactCompiler": true
    },
    "extra": {
      "router": {},
      "eas": {
        "projectId": "9ffdc9e1-c1e7-4340-be33-b14901420738"
      }
    },
    "owner": "q_allen"
  }
}
